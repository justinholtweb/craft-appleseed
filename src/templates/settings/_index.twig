{% extends "_layouts/cp" %}

{% set title = 'Appleseed Settings' %}
{% set selectedSubnavItem = 'settings' %}

{% block content %}

<form method="post" accept-charset="UTF-8">
    {{ csrfInput() }}
    {{ actionInput('appleseed/settings/save') }}
    {{ redirectInput('appleseed/settings') }}

    <h2>Link Checking</h2>

    {{ forms.lightswitchField({
        label: 'Check External Links',
        instructions: 'Whether to check links pointing to external domains.',
        id: 'checkExternalLinks',
        name: 'checkExternalLinks',
        on: settings.checkExternalLinks,
    }) }}

    {{ forms.textField({
        label: 'Timeout (seconds)',
        instructions: 'Maximum time to wait for a response from each URL.',
        id: 'timeout',
        name: 'timeout',
        value: settings.timeout,
        type: 'number',
        min: 1,
        max: 60,
        size: 5,
        errors: settings.getErrors('timeout'),
    }) }}

    {{ forms.textField({
        label: 'Max Retries',
        instructions: 'Number of retry attempts for failed requests (uses exponential backoff).',
        id: 'maxRetries',
        name: 'maxRetries',
        value: settings.maxRetries,
        type: 'number',
        min: 1,
        max: 10,
        size: 5,
        errors: settings.getErrors('maxRetries'),
    }) }}

    {{ forms.textField({
        label: 'Rate Limit (requests/second)',
        instructions: 'Maximum requests per second to the same domain.',
        id: 'rateLimitPerSecond',
        name: 'rateLimitPerSecond',
        value: settings.rateLimitPerSecond,
        type: 'number',
        step: '0.1',
        min: '0.1',
        max: '100',
        size: 5,
        errors: settings.getErrors('rateLimitPerSecond'),
    }) }}

    {{ forms.textField({
        label: 'User Agent',
        instructions: 'The User-Agent string sent with HTTP requests.',
        id: 'userAgent',
        name: 'userAgent',
        value: settings.userAgent,
        errors: settings.getErrors('userAgent'),
    }) }}

    <hr>
    <h2>Spider</h2>

    {{ forms.lightswitchField({
        label: 'Enable Spider',
        instructions: 'Crawl rendered pages via HTTP in addition to scanning the database.',
        id: 'spiderEnabled',
        name: 'spiderEnabled',
        on: settings.spiderEnabled,
    }) }}

    {{ forms.textField({
        label: 'Max Pages to Spider',
        instructions: 'Maximum number of pages the spider will visit per scan.',
        id: 'maxPagesToSpider',
        name: 'maxPagesToSpider',
        value: settings.maxPagesToSpider,
        type: 'number',
        min: 1,
        max: 10000,
        size: 5,
        errors: settings.getErrors('maxPagesToSpider'),
    }) }}

    <hr>
    <h2>Scheduling</h2>

    {{ forms.selectField({
        label: 'Scan Frequency',
        instructions: 'How often to automatically run a full scan.',
        id: 'scanFrequency',
        name: 'scanFrequency',
        value: settings.scanFrequency,
        options: [
            { label: 'Manual only', value: 'manual' },
            { label: 'Daily', value: 'daily' },
            { label: 'Weekly', value: 'weekly' },
            { label: 'Monthly', value: 'monthly' },
        ],
    }) }}

    {{ forms.lightswitchField({
        label: 'Scan on Entry Save',
        instructions: 'Automatically scan an entry for broken links whenever it is saved.',
        id: 'scanOnEntrySave',
        name: 'scanOnEntrySave',
        on: settings.scanOnEntrySave,
    }) }}

    <hr>
    <h2>Notifications</h2>

    {{ forms.textField({
        label: 'Notification Emails',
        instructions: 'Comma-separated email addresses to notify when broken links are found.',
        id: 'notificationEmails',
        name: 'notificationEmails',
        value: settings.notificationEmails,
        errors: settings.getErrors('notificationEmails'),
    }) }}

    {{ forms.textField({
        label: 'Notification Threshold',
        instructions: 'Minimum number of broken links before sending a notification.',
        id: 'notificationThreshold',
        name: 'notificationThreshold',
        value: settings.notificationThreshold,
        type: 'number',
        min: 1,
        size: 5,
        errors: settings.getErrors('notificationThreshold'),
    }) }}

    <hr>
    <h2>Ignore Patterns</h2>

    {{ forms.textareaField({
        label: 'Ignore Patterns',
        instructions: 'One regex pattern per line. URLs matching any pattern will be skipped during checking. Example: `/^https:\\/\\/example\\.com/`',
        id: 'ignorePatterns',
        name: 'ignorePatterns',
        value: settings.ignorePatterns,
        rows: 6,
        class: 'code',
        errors: settings.getErrors('ignorePatterns'),
    }) }}

    <div class="btngroup">
        <input type="submit" class="btn submit" value="Save">
    </div>
</form>

{% endblock %}
