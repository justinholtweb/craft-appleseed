<h1 style="font-size: 22px; margin-bottom: 5px;">Appleseed Scan Report</h1>
<p style="color: #666; margin-top: 0;">{{ scan.completedAt|date('F j, Y g:ia') }}</p>

<table style="width: 100%; border-collapse: collapse; margin: 20px 0;">
    <tr>
        <td style="padding: 12px; background: #f8f8f8; border: 1px solid #e5e5e5; text-align: center;">
            <div style="font-size: 28px; font-weight: 600;">{{ summary.total }}</div>
            <div style="font-size: 12px; color: #666; text-transform: uppercase;">Total</div>
        </td>
        <td style="padding: 12px; background: #fef2f2; border: 1px solid #e5e5e5; text-align: center;">
            <div style="font-size: 28px; font-weight: 600; color: #dc2626;">{{ summary.broken }}</div>
            <div style="font-size: 12px; color: #666; text-transform: uppercase;">Broken</div>
        </td>
        <td style="padding: 12px; background: #fffbeb; border: 1px solid #e5e5e5; text-align: center;">
            <div style="font-size: 28px; font-weight: 600; color: #d97706;">{{ summary.redirects }}</div>
            <div style="font-size: 12px; color: #666; text-transform: uppercase;">Redirects</div>
        </td>
        <td style="padding: 12px; background: #f0fdf4; border: 1px solid #e5e5e5; text-align: center;">
            <div style="font-size: 28px; font-weight: 600; color: #16a34a;">{{ summary.working }}</div>
            <div style="font-size: 12px; color: #666; text-transform: uppercase;">Working</div>
        </td>
    </tr>
</table>

{% if summary.broken > 0 %}
    <p>
        <strong>{{ summary.broken }} broken link{{ summary.broken != 1 ? 's' }}</strong> found during this scan.
        <a href="{{ cpUrl }}/appleseed/dashboard?status=broken" style="color: #2563eb;">View in dashboard &rarr;</a>
    </p>

    {% if brokenLinks|length %}
        <table style="width: 100%; border-collapse: collapse; margin: 20px 0; font-size: 13px;">
            <tr style="background: #fef2f2;">
                <th style="padding: 8px 10px; text-align: left; border: 1px solid #e5e5e5; font-weight: 600;">URL</th>
                <th style="padding: 8px 10px; text-align: center; border: 1px solid #e5e5e5; font-weight: 600; width: 60px;">Status</th>
                <th style="padding: 8px 10px; text-align: left; border: 1px solid #e5e5e5; font-weight: 600;">Error</th>
            </tr>
            {% for link in brokenLinks %}
                <tr>
                    <td style="padding: 8px 10px; border: 1px solid #e5e5e5; word-break: break-all;">
                        <a href="{{ link.url }}" style="color: #2563eb; text-decoration: none;">{{ link.url|length > 60 ? link.url[:60] ~ '...' : link.url }}</a>
                        {% if link.sources|length %}
                            <div style="margin-top: 4px; font-size: 11px; color: #888;">
                                Found in:
                                {% for source in link.sources[:3] %}
                                    {% if source.entryTitle is defined and source.entryTitle %}
                                        <a href="{{ source.entryCpUrl }}" style="color: #888;">{{ source.entryTitle }}</a>{{ not loop.last ? ', ' }}
                                    {% elseif source.sourceUrl is defined and source.sourceUrl %}
                                        {{ source.sourceUrl|length > 40 ? source.sourceUrl[:40] ~ '...' : source.sourceUrl }}{{ not loop.last ? ', ' }}
                                    {% endif %}
                                {% endfor %}
                                {% if link.sources|length > 3 %}
                                    <span>+{{ link.sources|length - 3 }} more</span>
                                {% endif %}
                            </div>
                        {% endif %}
                    </td>
                    <td style="padding: 8px 10px; border: 1px solid #e5e5e5; text-align: center; font-family: monospace;">
                        {{ link.statusCode ?? '—' }}
                    </td>
                    <td style="padding: 8px 10px; border: 1px solid #e5e5e5; color: #666;">
                        {% if link.status == 'dns_error' %}
                            DNS resolution failed
                        {% elseif link.status == 'timeout' %}
                            Connection timed out
                        {% elseif link.status == 'server_error' %}
                            Server error
                        {% elseif link.errorMessage %}
                            {{ link.errorMessage|length > 80 ? link.errorMessage[:80] ~ '...' : link.errorMessage }}
                        {% else %}
                            Not found
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
        </table>

        {% if brokenLinkCount > brokenLinks|length %}
            <p style="font-size: 13px; color: #666;">
                Showing {{ brokenLinks|length }} of {{ brokenLinkCount }} broken links.
                <a href="{{ cpUrl }}/appleseed/dashboard?status=broken" style="color: #2563eb;">View all in dashboard &rarr;</a>
            </p>
        {% endif %}
    {% endif %}
{% else %}
    <p style="color: #16a34a;">No broken links found. Everything looks good!</p>
{% endif %}
