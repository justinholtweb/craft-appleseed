<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Appleseed Scan Report</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #333; max-width: 600px; margin: 0 auto; padding: 20px;">

    <h1 style="font-size: 22px; margin-bottom: 5px;">Appleseed Scan Report</h1>
    <p style="color: #666; margin-top: 0;">{{ scan.completedAt|date('F j, Y g:ia') }}</p>

    <table style="width: 100%; border-collapse: collapse; margin: 20px 0;">
        <tr>
            <td style="padding: 12px; background: #f8f8f8; border: 1px solid #e5e5e5; text-align: center;">
                <div style="font-size: 28px; font-weight: 600;">{{ summary.total }}</div>
                <div style="font-size: 12px; color: #666; text-transform: uppercase;">Total</div>
            </td>
            <td style="padding: 12px; background: #fef2f2; border: 1px solid #e5e5e5; text-align: center;">
                <div style="font-size: 28px; font-weight: 600; color: #dc2626;">{{ summary.broken }}</div>
                <div style="font-size: 12px; color: #666; text-transform: uppercase;">Broken</div>
            </td>
            <td style="padding: 12px; background: #fffbeb; border: 1px solid #e5e5e5; text-align: center;">
                <div style="font-size: 28px; font-weight: 600; color: #d97706;">{{ summary.redirects }}</div>
                <div style="font-size: 12px; color: #666; text-transform: uppercase;">Redirects</div>
            </td>
            <td style="padding: 12px; background: #f0fdf4; border: 1px solid #e5e5e5; text-align: center;">
                <div style="font-size: 28px; font-weight: 600; color: #16a34a;">{{ summary.working }}</div>
                <div style="font-size: 12px; color: #666; text-transform: uppercase;">Working</div>
            </td>
        </tr>
    </table>

    {% if summary.broken > 0 %}
        <p>
            <strong>{{ summary.broken }} broken link{{ summary.broken != 1 ? 's' }}</strong> found during this scan.
            <a href="{{ cpUrl }}/appleseed/dashboard?status=broken" style="color: #2563eb;">View in dashboard &rarr;</a>
        </p>
    {% else %}
        <p style="color: #16a34a;">No broken links found. Everything looks good!</p>
    {% endif %}

    <hr style="border: none; border-top: 1px solid #e5e5e5; margin: 20px 0;">

    <p style="font-size: 12px; color: #999;">
        This email was sent by the Appleseed plugin for Craft CMS.
        <a href="{{ cpUrl }}/appleseed/settings" style="color: #999;">Manage notification settings</a>
    </p>

</body>
</html>
